# ---------- LLM backend ----------
# If you run Ollama/vLLM on the EC2 host:
LEGAL_AI_VLLM_BASE_URL=http://host.docker.internal:11434
LEGAL_AI_LLM_MODEL_NAME=llama3.2:3b

# ---------- RAG: Postgres pgvector ----------
# Use dedicated DB for AI agent (separate from app & admin).
LEGAL_AI_USE_PGVECTOR=true
LEGAL_AI_AGENT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/legal_ai_agent

# ---------- Optional ----------
# LEGAL_AI_DEBUG=false
# LEGAL_AI_RAG_TOP_K=3
# LEGAL_AI_LLM_MAX_TOKENS=2048
# LEGAL_AI_LLM_TEMPERATURE=0.3