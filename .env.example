# Legal Drafting AI - Example environment variables
# Copy to .env and adjust as needed.

# ---------- Ollama (local LLM) ----------
LEGAL_AI_VLLM_BASE_URL=http://localhost:11434
LEGAL_AI_LLM_MODEL_NAME=llama3

# ---------- vLLM (alternative) ----------
# LEGAL_AI_VLLM_BASE_URL=http://localhost:8001/v1
# LEGAL_AI_LLM_MODEL_NAME=meta-llama/Llama-3-8B-Instruct

# ---------- RAG: Postgres pgvector (AI agent’s own DB) ----------
# Use a dedicated database for the AI agent (separate from app API and admin-panel).
# LEGAL_AI_USE_PGVECTOR=true
# LEGAL_AI_AGENT_DATABASE_URL=postgresql://postgres:password@localhost:5432/legal_ai_agent
# Or if not set, LEGAL_AI_DATABASE_URL is used:
# LEGAL_AI_DATABASE_URL=postgresql://postgres:password@localhost:5432/legal_ai_agent

# ---------- Optional ----------
# LEGAL_AI_DEBUG=false
# LEGAL_AI_RAG_TOP_K=3
# LEGAL_AI_LLM_MAX_TOKENS=2048
# LEGAL_AI_LLM_TEMPERATURE=0.3
